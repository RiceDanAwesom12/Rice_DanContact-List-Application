<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Rice_DanContact_List_Application.Views.ContactDetailsPage">

    <VerticalStackLayout Padding="20">

        <Label Text="Name:" FontAttributes="Bold" />
        <Label Text="{Binding SelectedContact.Name}" />

        <Label Text="Email:" FontAttributes="Bold" />
        <Label Text="{Binding SelectedContact.Email}" />

        <Label Text="Phone:" FontAttributes="Bold" />
        <Label Text="{Binding SelectedContact.PhoneNumber}" />

        <Label Text="Description:" FontAttributes="Bold" />
        <Label Text="{Binding SelectedContact.Description}" />

        <Button Text="Save" Command="{Binding UpdateContactCommand}" />
        <Button Text="Back" Command="{Binding GoToAddPageCommand}" />

    </VerticalStackLayout>
</ContentPage>
